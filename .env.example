# Absolute Blockchain Ultimate — Environment Variables
# Copy to .env (optional). Never commit .env with real secrets.
#
# Tokenomics (educational model):
#   221,000,000 ABS max supply
#   Founder D.U.P. (Uladzimir Dabranski) — 17.4% = 38,454,000 ABS

# Weather oracles (optional — без ключей оракулы работают в demo-режиме)
OPENWEATHER_API_KEY=your_api_key_here
WEATHERAPI_KEY=your_api_key_here

# Telegram Bot Token (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# GitHub PAT for gh CLI / push (local .env only, never commit)
GITHUB_TOKEN=

# ECDSA private key (64 hex) — local .env only, never commit
WALLET_PRIVATE_KEY=

# Chain integrity (prod / node.example.json: true)
REQUIRE_SIGNATURES=false
ENFORCE_PROPOSER=true
VERIFY_PEER_STATE_ROOT=true

# JWT Secret (optional, API auth)
JWT_SECRET=your_jwt_secret_here

# Network ports (defaults match runtime/config.py)
RPC_PORT=8545
HTTP_PORT=8080
WS_PORT=8766
P2P_PORT=5000

# Industrial profile (optional)
DEPLOYMENT_MODE=dev
NODE_ID=node-1
DATA_DIR=./data
LOG_LEVEL=INFO
LOG_JSON=false
METRICS_ENABLED=true
JWT_ENFORCE_ADMIN=false
REQUIRE_WALLET_FILE=false
ENABLE_CORS_RPC_PROXY=true
CORS_ORIGINS=*
SQLITE_SYNCHRONOUS=NORMAL

# HA / Scale (Phase 5)
REDIS_URL=redis://localhost:6379/0
REDIS_RATE_LIMIT=false
RATE_LIMIT_RPM=120
BOOTSTRAP_PEERS=

# Bridge (devnet: manual confirm by default; prod: set BRIDGE_MODE=rust + binary path)
BRIDGE_ENABLED=true
BRIDGE_MODE=simulator
BRIDGE_AUTO_CONFIRM_SEC=0
CHAIN_ID=77777

# RPC API keys (prod) — generate: python scripts/generate_rpc_key.py
RPC_API_KEY_REQUIRED=false
RPC_API_KEYS=
