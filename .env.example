# Absolute Blockchain Ultimate — Environment Variables
# Copy to .env (optional). Never commit .env with real secrets.
#
# Tokenomics (educational model):
#   221,000,000 ABS max supply
#   Founder D.U.P. (Uladzimir Dabranski) — 17.4% = 38,454,000 ABS

# OpenWeather API Key (optional, weather oracle)
OPENWEATHER_API_KEY=your_api_key_here

# Telegram Bot Token (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# JWT Secret (optional, API auth)
JWT_SECRET=your_jwt_secret_here

# Network ports (defaults match runtime/config.py)
RPC_PORT=8545
HTTP_PORT=8080
WS_PORT=8766
P2P_PORT=5000
